<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1117"
    android:fillViewport="true">
    
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:gravity="center_horizontal">

        <!-- هدر -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="20dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🚀"
                android:textSize="32sp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="VPS One-Click"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#F0F6FC"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

        <!-- فیلد توکن گیت‌هاب -->
        <EditText
            android:id="@+id/tokenInput"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="🔑 توکن گیت‌هاب"
            android:inputType="textPassword"
            android:textColor="#F0F6FC"
            android:textColorHint="#8B949E"
            android:background="#161B22"
            android:padding="12dp"
            android:layout_marginBottom="12dp"/>

        <!-- فیلد کلید Tailscale -->
        <EditText
            android:id="@+id/tailscaleInput"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="🔗 کلید Tailscale (tskey-auth-...)"
            android:inputType="text"
            android:textColor="#F0F6FC"
            android:textColorHint="#8B949E"
            android:background="#161B22"
            android:padding="12dp"
            android:layout_marginBottom="16dp"/>

        <!-- دکمه اصلی -->
        <Button
            android:id="@+id/oneClickBtn"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="⚡ یک‌کلیک VPS"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="#2EA043"
            android:layout_marginBottom="16dp"/>

        <!-- وضعیت -->
        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⏳ آماده برای شروع..."
            android:textColor="#8B949E"
            android:padding="12dp"
            android:background="#161B22"
            android:layout_marginBottom="8dp"/>

        <!-- نتیجه -->
        <TextView
            android:id="@+id/resultText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#F0F6FC"
            android:padding="12dp"
            android:background="#161B22"
            android:textSize="13sp"/>

        <!-- دکمه کپی -->
        <Button
            android:id="@+id/copyBtn"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="📋 کپی لینک SSH"
            android:textColor="#FFFFFF"
            android:background="#30363D"
            android:visibility="gone"
            android:layout_marginTop="12dp"/>
    </LinearLayout>
</ScrollView>
